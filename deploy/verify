#!/usr/bin/env bash
# deploy/verify — hardened post-deploy verification for polytrader
#
# Runs the full matrix after make k8s-apply (or any rollout):
# - Pod health + exact image (TS tag)
# - Log milestones (MAIN ENTERED, shutdown, L2 auto-derive success, no crash)
# - In-cluster /health + /l2/status + read-only CLOB diagnostics/operator rollup + dry-run audit (via temp curl pod)
# - SSR fidelity greps via local port-forward ( <base>, L2 chip, Derive button, legacy note, Phase ids, no 404)
# - Dashboard JavaScript syntax + subpath CLOB diagnostics/operator rollup and dry-run audit markers
# - Hermes status
# - Public ngrok spot-check (if reachable)
#
# Usage:
#   chmod +x deploy/verify
#   ./deploy/verify
#
# Part of rust_daytrader-inspired guardrails + repeatable deploy/verify flow.
set -euo pipefail

NAMESPACE="polytrader"
PUBLIC_URL="https://unground-uncraftily-vivienne.ngrok-free.dev/polytrader"

require_file_contains() {
  local file="$1"
  local pattern="$2"
  local label="$3"
  if ! grep -Eq "$pattern" "$file"; then
    echo "ERROR: required marker missing: $label"
    echo "       Pattern: $pattern"
    echo "       File: $file"
    exit 1
  fi
}

echo "============================================================"
echo "  POLYTRADER HARDENED DEPLOY/VERIFY"
echo "  (guardrails + unique-TS + scratch+musl + L2 + SSR fidelity)"
echo "============================================================"
echo ""

# 1. Identify newest pod + image
echo "==> 1. Current polytrader pod + image (post unique-TS set-image)"
POD=$(kubectl get pod -n "$NAMESPACE" -l app=polytrader \
  --sort-by=.metadata.creationTimestamp \
  -o jsonpath='{.items[-1].metadata.name}' 2>/dev/null || echo "")
if [[ -z "$POD" ]]; then
  echo "ERROR: No polytrader pod found in $NAMESPACE"
  exit 1
fi
IMAGE=$(kubectl get pod -n "$NAMESPACE" "$POD" -o jsonpath='{.spec.containers[0].image}' 2>/dev/null || echo "")
READY=$(kubectl get pod -n "$NAMESPACE" "$POD" -o jsonpath='{.status.conditions[?(@.type=="Ready")].status}' 2>/dev/null || echo "False")
RESTARTS=$(kubectl get pod -n "$NAMESPACE" "$POD" -o jsonpath='{.status.containerStatuses[0].restartCount}' 2>/dev/null || echo "0")

echo "  Pod:      $POD"
echo "  Image:    $IMAGE"
echo "  Ready:    $READY"
echo "  Restarts: $RESTARTS"
echo ""

if [[ "$READY" != "True" ]]; then
  echo "WARNING: Pod not Ready yet — waiting 30s..."
  kubectl wait --for=condition=ready "pod/$POD" -n "$NAMESPACE" --timeout=30s || true
  READY=$(kubectl get pod -n "$NAMESPACE" "$POD" -o jsonpath='{.status.conditions[?(@.type=="Ready")].status}' 2>/dev/null || echo "False")
  RESTARTS=$(kubectl get pod -n "$NAMESPACE" "$POD" -o jsonpath='{.status.containerStatuses[0].restartCount}' 2>/dev/null || echo "0")
fi

if [[ "$READY" != "True" ]]; then
  echo "ERROR: Pod $POD is not Ready after wait (Ready=$READY)"
  kubectl describe pod -n "$NAMESPACE" "$POD" 2>/dev/null | tail -80 || true
  exit 1
fi

if [[ "$RESTARTS" != "0" ]]; then
  echo "ERROR: Pod $POD has non-zero restart count (Restarts=$RESTARTS)"
  kubectl get pod -n "$NAMESPACE" "$POD" -o wide 2>/dev/null || true
  echo "       Previous logs, if available:"
  kubectl logs -n "$NAMESPACE" "$POD" --previous --tail=80 2>/dev/null || true
  exit 1
fi

# 2. Logs — key sequence + L2 derive + no crash markers
echo "==> 2. Logs (key startup + L2 + no Exit 0 / crash signals)"
echo "     (use kubectl logs -p --previous for prior if CrashLoop)"
kubectl logs -n "$NAMESPACE" "$POD" --tail=80 2>/dev/null | cat
echo ""
echo "     --- L2 / startup grep ---"
kubectl logs -n "$NAMESPACE" "$POD" --tail=120 2>/dev/null | grep -E \
  '=== POLYTRADER MAIN ENTERED|ABOUT TO CALL start_server|ENTERED start_server|starting axum server|L2 auto-derive|POLYMARKET_PRIVATE_KEY_FILE|Connected.*server key|server key.*auto|shutdown_signal|graceful' || echo "     (some milestones may appear later; re-run after full init)"
echo ""

# 3. In-cluster API checks (/health + /l2/status + read-only CLOB diagnostics/operator rollup + dry-run audit)
echo "==> 3. In-cluster API checks (/health, /l2/status, CLOB diagnostics/operator, dry-run audit)"
# One-shot curl pod (uses public curl image; cleans up). These checks are
# blocking because they verify service routing inside the cluster, not just SSR.
IN_CLUSTER_OUT="/tmp/polytrader-in-cluster-verify.out"
set +e
kubectl run -n "$NAMESPACE" curl-verify --rm --attach -i --restart=Never --image=curlimages/curl:8.6.0 -- \
  sh -ec '
    echo "GET /health:";
    HEALTH=$(curl -fsS --max-time 5 http://polytrader:80/health);
    echo "$HEALTH";
    echo "$HEALTH" | grep -q "\"status\":\"ok\"";
    echo "";
    echo "GET /l2/status:";
    L2=$(curl -fsS --max-time 5 http://polytrader:80/l2/status);
    echo "$L2";
    echo "$L2" | grep -q "\"paper_only\":true";
    echo "$L2" | grep -q "\"connected\":true";
    echo "";
    echo "GET /clob/status:";
