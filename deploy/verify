    echo "$CLOB" | grep -q "\"paper_only\":true";
    echo "$CLOB" | grep -q "\"real_orders_enabled\":false";
    echo "";
    echo "GET /clob/account:";
    ACCOUNT=$(curl -fsS --max-time 8 http://polytrader:80/clob/account);
    echo "$ACCOUNT";
    echo "$ACCOUNT" | grep -q "\"l2_connected\":true";
    echo "$ACCOUNT" | grep -q "\"read_only_live_check\":true";
    echo "$ACCOUNT" | grep -q "\"paper_only\":true";
    echo "$ACCOUNT" | grep -q "\"real_orders_enabled\":false";
    echo "$ACCOUNT" | grep -q "\"account\":";
    echo "$ACCOUNT" | grep -q "\"open_orders\":";
    echo "$ACCOUNT" | grep -q "\"collateral\":";
    echo "";
    echo "GET /clob/preflight:";
    PREFLIGHT=$(curl -fsS --max-time 8 http://polytrader:80/clob/preflight);
    echo "$PREFLIGHT";
    echo "$PREFLIGHT" | grep -q "\"l2_connected\":true";
    echo "$PREFLIGHT" | grep -q "\"read_only_live_check\":true";
    echo "$PREFLIGHT" | grep -q "\"paper_only\":true";
    echo "$PREFLIGHT" | grep -q "\"real_orders_enabled\":false";
	    echo "$PREFLIGHT" | grep -q "\"ready_for_real_orders\":false";
	    echo "$PREFLIGHT" | grep -q "\"blockers\":";
	    echo "$PREFLIGHT" | grep -q "\"checks\":";
	    echo "";
	    echo "GET /clob/diagnostics:";
	    DIAGNOSTICS=$(curl -fsS --max-time 10 http://polytrader:80/clob/diagnostics);
	    echo "$DIAGNOSTICS";
	    echo "$DIAGNOSTICS" | grep -q "\"l2_connected\":true";
	    echo "$DIAGNOSTICS" | grep -q "\"read_only_live_check\":true";
	    echo "$DIAGNOSTICS" | grep -q "\"paper_only\":true";
	    echo "$DIAGNOSTICS" | grep -q "\"real_orders_enabled\":false";
	    echo "$DIAGNOSTICS" | grep -q "\"ready_for_real_orders\":false";
	    echo "$DIAGNOSTICS" | grep -q "\"status\":";
		    echo "$DIAGNOSTICS" | grep -q "\"account\":";
		    echo "$DIAGNOSTICS" | grep -q "\"preflight\":";
		    echo "";
		    echo "GET /clob/collateral-readiness:";
		    COLLATERAL_READINESS=$(curl -fsS --max-time 10 http://polytrader:80/clob/collateral-readiness);
		    echo "$COLLATERAL_READINESS";
		    echo "$COLLATERAL_READINESS" | grep -q "\"paper_only\":true";
		    echo "$COLLATERAL_READINESS" | grep -q "\"real_orders_enabled\":false";
		    echo "$COLLATERAL_READINESS" | grep -q "\"journaled\":true";
		    echo "$COLLATERAL_READINESS" | grep -q "\"journal_event_id\":";
		    echo "$COLLATERAL_READINESS" | grep -q "\"collateral_readiness\":";
		    echo "$COLLATERAL_READINESS" | grep -q "\"request_sent\":false";
		    echo "$COLLATERAL_READINESS" | grep -q "\"post_order_called\":false";
		    echo "";
		    echo "GET /clob/operator-status?limit=10:";
		    OPERATOR_STATUS=$(curl -fsS --max-time 10 "http://polytrader:80/clob/operator-status?limit=10");
		    echo "$OPERATOR_STATUS";
		    echo "$OPERATOR_STATUS" | grep -q "\"paper_only\":true";
		    echo "$OPERATOR_STATUS" | grep -q "\"real_orders_enabled\":false";
		    echo "$OPERATOR_STATUS" | grep -q "\"ready_for_real_orders\":false";
		    echo "$OPERATOR_STATUS" | grep -q "\"operator_status\":";
		    echo "$OPERATOR_STATUS" | grep -q "\"clob\":";
		    echo "$OPERATOR_STATUS" | grep -q "\"review\":";
		    echo "$OPERATOR_STATUS" | grep -q "\"recommended_next_actions\":";
		    echo "";
		    echo "GET /clob/order-intent/dry-runs?limit=3:";
		    DRY_RUNS=$(curl -fsS --max-time 8 "http://polytrader:80/clob/order-intent/dry-runs?limit=3");
		    echo "$DRY_RUNS";
		    echo "$DRY_RUNS" | grep -q "\"paper_only\":true";
		    echo "$DRY_RUNS" | grep -q "\"real_orders_enabled\":false";
		    echo "$DRY_RUNS" | grep -q "\"event_type\":\"clob_order_intent_dry_run\"";
		    echo "$DRY_RUNS" | grep -q "\"events\":";
		    echo "";
		    echo "GET /clob/order-intent/reviews?limit=3:";
		    REVIEWS=$(curl -fsS --max-time 8 "http://polytrader:80/clob/order-intent/reviews?limit=3");
		    echo "$REVIEWS";
		    echo "$REVIEWS" | grep -q "\"paper_only\":true";
		    echo "$REVIEWS" | grep -q "\"real_orders_enabled\":false";
		    echo "$REVIEWS" | grep -q "\"event_type\":\"clob_order_intent_review\"";
		    echo "$REVIEWS" | grep -q "\"decision_counts\":";
		    echo "";
		    echo "GET /clob/order-intent/review-summary?limit=10:";
		    REVIEW_SUMMARY=$(curl -fsS --max-time 8 "http://polytrader:80/clob/order-intent/review-summary?limit=10");
		    echo "$REVIEW_SUMMARY";
		    echo "$REVIEW_SUMMARY" | grep -q "\"paper_only\":true";
		    echo "$REVIEW_SUMMARY" | grep -q "\"real_orders_enabled\":false";
		    echo "$REVIEW_SUMMARY" | grep -q "\"summary\":";
		    echo "$REVIEW_SUMMARY" | grep -q "\"items\":";
		    echo "";
		    echo "GET /clob/order-intent/review-health?limit=10:";
		    REVIEW_HEALTH=$(curl -fsS --max-time 8 "http://polytrader:80/clob/order-intent/review-health?limit=10");
		    echo "$REVIEW_HEALTH";
		    echo "$REVIEW_HEALTH" | grep -q "\"paper_only\":true";
		    echo "$REVIEW_HEALTH" | grep -q "\"real_orders_enabled\":false";
		    echo "$REVIEW_HEALTH" | grep -q "\"health\":";
		    echo "$REVIEW_HEALTH" | grep -q "\"recommended_actions\":";
		    echo "";
		    echo "GET /clob/order-intent/review-backlog:";
		    REVIEW_BACKLOG=$(curl -fsS --max-time 8 "http://polytrader:80/clob/order-intent/review-backlog");
		    echo "$REVIEW_BACKLOG";
		    echo "$REVIEW_BACKLOG" | grep -q "\"paper_only\":true";
		    echo "$REVIEW_BACKLOG" | grep -q "\"real_orders_enabled\":false";
		    echo "$REVIEW_BACKLOG" | grep -Eq "\"status\":\"(empty|fresh|stale)\"";
		    echo "";
		    echo "GET /clob/order-intent/review-queue?limit=3:";
		    REVIEW_QUEUE=$(curl -fsS --max-time 8 "http://polytrader:80/clob/order-intent/review-queue?limit=3");
		    echo "$REVIEW_QUEUE";
		    echo "$REVIEW_QUEUE" | grep -q "\"paper_only\":true";
		    echo "$REVIEW_QUEUE" | grep -q "\"real_orders_enabled\":false";
		    echo "$REVIEW_QUEUE" | grep -q "\"review_stale_after_seconds\":";
		    echo "$REVIEW_QUEUE" | grep -q "\"items\":";
		    echo "$REVIEW_QUEUE" | grep -Eq "\"review_priority\":\"(stale_unreviewed|blocked_unreviewed|standard_unreviewed)\"|\"count\":0";
		    echo "";
		    echo "GET /clob/order-intent/review-guidance-exceptions?limit=3:";
		    GUIDANCE_EXCEPTIONS=$(curl -fsS --max-time 8 "http://polytrader:80/clob/order-intent/review-guidance-exceptions?limit=3");
		    echo "$GUIDANCE_EXCEPTIONS";
		    echo "$GUIDANCE_EXCEPTIONS" | grep -q "\"paper_only\":true";
		    echo "$GUIDANCE_EXCEPTIONS" | grep -q "\"real_orders_enabled\":false";
		    echo "$GUIDANCE_EXCEPTIONS" | grep -q "\"items\":";
		    echo "";
		    echo "GET /clob/order-intent/review-guidance-overrides?limit=3:";
		    GUIDANCE_OVERRIDES=$(curl -fsS --max-time 8 "http://polytrader:80/clob/order-intent/review-guidance-overrides?limit=3");
		    echo "$GUIDANCE_OVERRIDES";
		    echo "$GUIDANCE_OVERRIDES" | grep -q "\"paper_only\":true";
		    echo "$GUIDANCE_OVERRIDES" | grep -q "\"real_orders_enabled\":false";
		    echo "$GUIDANCE_OVERRIDES" | grep -q "\"items\":";
		    echo "";
		  ' >"$IN_CLUSTER_OUT" 2>&1
IN_CLUSTER_STATUS=$?
set -e
cat "$IN_CLUSTER_OUT"
if [[ "$IN_CLUSTER_STATUS" != "0" ]]; then
  echo "ERROR: in-cluster API verification failed"
  exit 1
fi
echo ""

# 4. SSR + UI fidelity (local port-forward + grep for L2 primary, Google legacy, <base>, Phase branding, ids)
echo "==> 4. SSR + UI fidelity checks (subpath routes, CLOB diagnostics, dry-run audit panels)"
PF_LOG="/tmp/pf-verify.log"
PF_PID=""
cleanup_pf() {
  if [[ -n "${PF_PID:-}" ]]; then
    kill "$PF_PID" 2>/dev/null || true
    wait "$PF_PID" 2>/dev/null || true
  fi
}
trap cleanup_pf EXIT
kubectl port-forward -n "$NAMESPACE" svc/polytrader 18080:80 >"$PF_LOG" 2>&1 &
PF_PID=$!
sleep 4
HTML_FILE="/tmp/polytrader-dashboard-verify.html"
STATUS_FILE="/tmp/polytrader-clob-status-subpath-verify.json"
ACCOUNT_FILE="/tmp/polytrader-clob-account-subpath-verify.json"
	PREFLIGHT_FILE="/tmp/polytrader-clob-preflight-subpath-verify.json"
	DIAGNOSTICS_FILE="/tmp/polytrader-clob-diagnostics-subpath-verify.json"
